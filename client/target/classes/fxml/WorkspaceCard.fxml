<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dvcs.client.dashboard.workspace.WorkspaceCardController"
      spacing="10" styleClass="workspace-card">

    <padding>
        <Insets top="14" right="14" bottom="14" left="14"/>
    </padding>

    <Rectangle width="28" height="22" arcWidth="8" arcHeight="8" styleClass="workspace-icon"/>

    <Label fx:id="titleLabel" text="Workspace" styleClass="workspace-title"/>
</VBox>
