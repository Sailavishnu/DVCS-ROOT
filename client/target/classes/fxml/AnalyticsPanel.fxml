<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.dvcs.client.dashboard.analytics.AnalyticsPanelController"
    spacing="20" prefWidth="300" styleClass="analytics-panel">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label text="Workspace Activity" styleClass="panel-title"/>

    <Label fx:id="taglineLabel" text="Keep your docs moving." styleClass="panel-tagline" wrapText="true"/>

    <LineChart fx:id="activityChart" animated="false" legendVisible="false" createSymbols="false"
               styleClass="activity-chart" minHeight="260" prefHeight="280" VBox.vgrow="ALWAYS">
        <xAxis>
            <CategoryAxis fx:id="xAxis"/>
        </xAxis>
        <yAxis>
            <NumberAxis fx:id="yAxis" autoRanging="true"/>
        </yAxis>
    </LineChart>

    <VBox spacing="14">
        <VBox styleClass="stat-tile" spacing="2">
            <Label text="Commits" styleClass="stat-label"/>
            <Label fx:id="commitsValue" text="—" styleClass="stat-value"/>
        </VBox>

        <VBox styleClass="stat-tile" spacing="2">
            <Label text="Active Workspaces" styleClass="stat-label"/>
            <Label fx:id="activeWorkspacesValue" text="—" styleClass="stat-value"/>
        </VBox>

        <VBox styleClass="stat-tile" spacing="4">
            <Label text="Highlights" styleClass="stat-label"/>
            <Label fx:id="highlightsLabel" text="—" styleClass="panel-body" wrapText="true"/>
        </VBox>
    </VBox>
</VBox>
