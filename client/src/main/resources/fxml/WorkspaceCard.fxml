<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dvcs.client.dashboard.workspace.WorkspaceCardController"
      spacing="8" styleClass="workspace-card-wrapper">

    <StackPane styleClass="workspace-card">
        <ImageView fx:id="iconImageView" styleClass="workspace-card-image" fitWidth="200" fitHeight="120" preserveRatio="false" smooth="true"/>
    </StackPane>

    <Label fx:id="titleLabel" text="Workspace" styleClass="workspace-title" wrapText="true"/>
</VBox>
