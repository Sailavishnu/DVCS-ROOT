<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dvcs.client.dashboard.navbar.NavbarController"
            alignment="CENTER_LEFT" spacing="18" prefHeight="76"
      styleClass="navbar">

    <padding>
                <Insets top="14" right="22" bottom="14" left="22"/>
    </padding>

    <Label text="DVCS" styleClass="navbar-title"/>

    <Region HBox.hgrow="ALWAYS"/>

      <TextField fx:id="searchField" promptText="Search workspaces, docs, and activity" styleClass="navbar-search" prefWidth="460" onAction="#onSearchSubmit"/>

      <Label fx:id="searchIconLabel" text="&#x1F50D;" styleClass="navbar-icon" onMouseClicked="#onSearchIconClick"/>

      <Label fx:id="notificationLabel" text="&#x1F514;" styleClass="navbar-icon" onMouseClicked="#onNotificationClick"/>

    <Circle radius="14" styleClass="navbar-avatar"/>
</HBox>
